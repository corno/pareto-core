{
  "name": "pareto-core",
  "version": "0.1.239",
  "license": "Apache-2.0",
  "author": "Corno",
  "description": "the core language constructs for the Pareto programming language (in TypeScript)",
  "keywords": [
    "pareto",
    "core",
    "language-constructs"
  ],
  "homepage": "https://github.com/corno/pareto-core#readme",
  "bugs": {
    "url": "https://github.com/corno/pareto-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/corno/pareto-core.git"
  },
  "dependencies": {},
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./implementation/command": {
      "default": "./dist/implementation/command/index.js"
    },
    "./implementation/production": {
      "default": "./dist/implementation/production/index.js"
    },
    "./implementation/refiner": {
      "default": "./dist/implementation/refiner/index.js"
    },
    "./implementation/transformer": {
      "default": "./dist/implementation/transformer/index.js"
    },
    "./implementation/*": {
      "default": "./dist/implementation/*.js"
    },
    "./interface/command": {
      "types": "./dist/interface/command/index.d.ts"
    },
    "./interface/data": {
      "types": "./dist/interface/data/index.d.ts"
    },
    "./interface/production": {
      "types": "./dist/interface/production/index.d.ts"
    },
    "./interface/query": {
      "types": "./dist/interface/query/index.d.ts"
    },
    "./interface/refiner": {
      "types": "./dist/interface/refiner/index.d.ts"
    },
    "./interface/transformer": {
      "types": "./dist/interface/transformer/index.d.ts"
    },
    "./interface/*": {
      "types": "./dist/interface/*.d.ts"
    },
    "./temp/*": {
      "types": "./dist/temp/*.d.ts",
      "default": "./dist/temp/*.js"
    }
  }
}
